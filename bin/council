#!/usr/bin/env node
// council — an agentic OpenRouter harness that Claude Code (or you) can shell
// out to for plan / build / test, with REAL local-file access (the model reads,
// greps, and globs the tree itself via a tool loop) and an optional multi-model
// "LLM council" mode that fans out to a panel and reconciles.
//
// Companion to `codex` (OpenAI) and `xcheck` (single-shot OpenRouter review).
// Where xcheck only submits a diff/file/stdin, council gives the chosen model a
// tool loop so it can navigate the codebase, and — under --sandbox write — edit
// files and run commands confined to --root.
//
// Zero npm deps: native fetch, util.parseArgs, fs/child_process. Node >= 22.
// Auth: OPENROUTER_API_KEY (https://openrouter.ai/keys).
'use strict';

const fs = require('node:fs');
const fsp = require('node:fs/promises');
const path = require('node:path');
const readline = require('node:readline');
const { spawn } = require('node:child_process');
const { parseArgs } = require('node:util');

// ---------------------------------------------------------------------------
// Defaults — match Dang's existing stack (xcheck / codex model ids).
// ---------------------------------------------------------------------------
const OR_URL = 'https://openrouter.ai/api/v1/chat/completions';
const DEFAULT_MODEL = process.env.COUNCIL_MODEL || 'google/gemini-3.1-pro-preview';
// Cross-lab panel (Google + OpenAI + Anthropic) — decorrelated seats, all verified
// on OpenRouter. GLM is omitted by default (provider rate-limits); add it back with
// COUNCIL_PANEL=... if you want it. Council tolerates a member failing.
const DEFAULT_PANEL = (process.env.COUNCIL_PANEL || 'google/gemini-3.1-pro-preview,openai/gpt-5.5,anthropic/claude-opus-4.8')
  .split(',').map((s) => s.trim()).filter(Boolean);
const DEFAULT_CHAIR = process.env.COUNCIL_CHAIR || 'google/gemini-3.1-pro-preview';

const MAX_STEPS = 30;          // tool-call iterations per agent
const READ_CAP = 256 * 1024;   // bytes returned per read_file
const HARD_READ_MAX = 32 * 1024 * 1024; // never load a whole file bigger than this
const SEED_CAP = 512 * 1024;   // bytes per -f seed file
const RUN_CAP = 64 * 1024;     // bytes captured per stream from run/grep
const RUN_TIMEOUT_MS = 180_000;
const RUN_KILL_GRACE_MS = 4_000; // SIGTERM → SIGKILL escalation window
const GREP_CAP = 200;          // max grep matches returned (per file, ripgrep -m)
const HTTP_TIMEOUT_MS = 600_000;

const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
// child process groups spawned by run(), so SIGINT/exit can reap them
const activeKids = new Set();
const reapKids = () => { for (const pid of activeKids) { try { process.kill(-pid, 'SIGKILL'); } catch { /* gone */ } } };
process.on('SIGINT', () => { reapKids(); process.exit(130); });
process.on('SIGTERM', () => { reapKids(); process.exit(143); });
// env handed to run(): strip the harness's own OpenRouter key so the model
// can't read or exfiltrate it. Other env (DATABASE_URL etc.) is inherited so
// real build/test commands still work.
const childEnv = () => { const e = { ...process.env }; delete e.OPENROUTER_API_KEY; return e; };

// Speed-bump denylist for `run` — NOT a security boundary, just a guard against
// the obvious foot-guns. Real isolation needs a container; see --help.
const RUN_DENY = [
  /\brm\s+-[rf]*[rf]\b[^|;&]*\s(\/|~|\$HOME|\.\.)([\s/*]|$)/, // rm -rf / ~ $HOME .. (and /* ~/.* globs)
  /\bsudo\b/, /\bmkfs\b/, /\bdd\b[^|]*\bof=\/dev/, /\bfind\b[^|]*-delete\b/,
  /:\s*\(\)\s*\{.*\}\s*;\s*:/, />\s*\/dev\/(sd|nvme|disk)/, /\bgit\s+push\b/,
  /\b(npm|yarn|pnpm|bun)\s+publish\b/, /\bcurl\b[^|]*\|\s*(sudo\s+)?(ba)?sh\b/,
  /\bshutdown\b|\breboot\b|\bhalt\b/,
];

// ---------------------------------------------------------------------------
// Small pure helpers
// ---------------------------------------------------------------------------
const die = (msg, code = 1) => { process.stderr.write(`council: ${msg}\n`); process.exit(code); };
const clip = (s, n) => (s.length > n ? `${s.slice(0, n)}\n…[truncated ${s.length - n} bytes]` : s);
const csv = (s) => String(s || '').split(',').map((x) => x.trim()).filter(Boolean);

// OpenRouter provider routing. primary + backup become an ordered preference
// list (provider.order); allow_fallbacks=false means "only these, in this order"
// (errors if none serve the model), true means "prefer these, then anyone".
// No providers + allowFallbacks=false ⇒ {allow_fallbacks:false} = the prior default.
const buildProvider = (primary, backup, allowFallbacks) => {
  const order = [...csv(primary), ...csv(backup)];
  const p = { allow_fallbacks: !!allowFallbacks };
  if (order.length) p.order = order;
  return p;
};

const MODES = {
  ask:    { sandbox: 'read-only', system:
    'You are a senior engineer answering a question about a codebase. Use the tools to read the actual code before answering — never guess. Answer concretely and concisely, citing file:line for every claim. If the answer is not determinable from the code, say so.' },
  plan:   { sandbox: 'read-only', system:
    'You are a senior engineer producing an IMPLEMENTATION PLAN. Explore the codebase with the tools before planning — read the real files, do not assume. Output: (1) a short restatement of the goal, (2) the concrete files/functions to change with why, (3) ordered steps, (4) risks & test strategy. Ground every claim in code you actually read; cite file:line.' },
  review: { sandbox: 'read-only', system:
    'You are an adversarial senior reviewer. Use the tools to read the relevant code, then output FINDINGS ONLY (no praise): each with a [BLOCKER]/[CONCERN]/[NIT] tag, the file:line, the concrete failure condition, and a repro or the broken invariant. Separate confirmed bugs from speculation. Do not invent issues; if nothing is blocker-grade, say so in one line.' },
  build:  { sandbox: 'write', system:
    'You are a senior engineer IMPLEMENTING a change. Read the relevant code first, make the smallest correct edits with edit_file/write_file (confined to the workspace root), then run the build/tests with run to verify. Report what you changed (file:line) and the verification result. Do not touch unrelated code.' },
  test:   { sandbox: 'write', system:
    'You are a senior engineer. Use run to execute the project\'s tests/build, read failing files to diagnose, and report a concise pass/fail summary with root causes for any failures and the exact failing assertions. Prefer running the narrowest test target first.' },
};

// ---------------------------------------------------------------------------
// Path confinement — every file/dir/glob op must stay within `root`.
// Resolves symlinks on the deepest existing ancestor to defeat symlink escapes.
// ---------------------------------------------------------------------------
const makeGuard = (root) => {
  const realRoot = fs.realpathSync(root);
  const within = (p) => p === realRoot || p.startsWith(realRoot + path.sep);
  return (rel) => {
    const abs = path.resolve(realRoot, rel);
    let probe = abs;
    // walk up to the nearest existing ancestor, realpath it, re-append the tail
    const tail = [];
    while (!fs.existsSync(probe)) {
      tail.unshift(path.basename(probe));
      const parent = path.dirname(probe);
      if (parent === probe) break;
      probe = parent;
    }
    const realProbe = fs.realpathSync(probe);
    const real = tail.length ? path.join(realProbe, ...tail) : realProbe;
    if (!within(real)) throw new Error(`path escapes workspace root: ${rel}`);
    return real;
  };
};

// ---------------------------------------------------------------------------
// Tools (data-in / data-out). Each returns a string the model sees.
// ---------------------------------------------------------------------------
const makeTools = (root, guard, caps) => {
  const rel = (p) => path.relative(root, p) || '.';

  const read_file = async ({ file, start_line, end_line }) => {
    const abs = guard(file);
    const st = await fsp.stat(abs);
    if (st.isDirectory()) throw new Error(`${file} is a directory (use list_dir)`);
    // Paged read: stream line-by-line so a huge file never lands fully in memory.
    if (start_line || end_line) {
      const s = Math.max(1, start_line || 1), e = end_line || Infinity;
      if (e < s) throw new Error(`end_line (${end_line}) is before start_line (${s})`);
      const input = fs.createReadStream(abs, 'utf8');
      const rl = readline.createInterface({ input, crlfDelay: Infinity });
      const out = []; let n = 0, bytes = 0, capped = false;
      try {
        for await (const line of rl) {
          n += 1;
          if (n >= s && n <= e) { out.push(`${n}\t${line}`); bytes += line.length + 1; }
          if (n > e) break;
          if (bytes > READ_CAP) { capped = true; break; }
        }
      } finally { rl.close(); input.destroy(); } // release the fd on every exit (cap/range/EOF)
      const body = clip(out.join('\n'), READ_CAP) + (capped ? '\n…[range truncated at cap]' : '');
      return out.length ? body : `(no lines in range; scanned ${n} lines)`;
    }
    // Whole-file read: refuse anything that would be wasteful or fatal to buffer.
    if (st.size > HARD_READ_MAX) throw new Error(`${rel(abs)} is ${st.size} bytes — too large to read whole; page it with start_line/end_line`);
    if (st.size > READ_CAP) return `[${rel(abs)} is ${st.size} bytes > ${READ_CAP} cap; pass start_line/end_line to page it]`;
    const text = (await fsp.readFile(abs, 'utf8')).replace(/\n$/, '');
    return clip(text.split('\n').map((l, i) => `${i + 1}\t${l}`).join('\n'), READ_CAP);
  };

  const list_dir = async ({ dir = '.', recursive = false }) => {
    const abs = guard(dir);
    if (recursive) {
      const out = [];
      const walk = async (d, depth) => {
        if (depth > 6) return;
        for (const ent of await fsp.readdir(d, { withFileTypes: true })) {
          if (ent.name === '.git' || ent.name === 'node_modules' || ent.name.startsWith('.DS')) continue;
          const p = path.join(d, ent.name);
          out.push(rel(p) + (ent.isDirectory() ? '/' : ''));
          if (ent.isDirectory()) await walk(p, depth + 1);
          if (out.length > 2000) return;
        }
      };
      await walk(abs, 0);
      return out.join('\n') || '(empty)';
    }
    const ents = await fsp.readdir(abs, { withFileTypes: true });
    return ents.map((e) => e.name + (e.isDirectory() ? '/' : '')).sort().join('\n') || '(empty)';
  };

  const glob = async ({ pattern }) => {
    try {
      const out = [];
      for await (const m of fsp.glob(pattern, { cwd: root })) {
        out.push(m);
        if (out.length > 1000) break;
      }
      // confine results
      return out.filter((m) => { try { guard(m); return true; } catch { return false; } })
        .join('\n') || '(no matches)';
    } catch (e) {
      return `glob unsupported on this Node (${e.message}); use list_dir recursive:true + grep`;
    }
  };

  const grep = ({ pattern, path: where = '.', glob: g }) =>
    new Promise((resolve) => {
      const abs = guard(where);
      const args = ['--no-heading', '--line-number', '--color', 'never', '-m', String(GREP_CAP)];
      if (g) args.push('-g', g);
      args.push('-e', pattern, abs);
      const rg = spawn('rg', args, { cwd: root });
      let out = '', err = '', capped = false;
      rg.stdout.on('data', (d) => {
        if (capped) return;
        if (out.length + d.length > RUN_CAP) { out += String(d).slice(0, RUN_CAP - out.length); capped = true; rg.kill('SIGTERM'); }
        else out += d;
      });
      rg.stderr.on('data', (d) => { if (err.length < RUN_CAP) err += d; });
      rg.on('error', () => resolve('[ripgrep not installed — narrow with list_dir + read_file instead]'));
      rg.on('close', (code) => {
        if (code === 1 && !out) return resolve('(no matches)');
        if (code !== 0 && code !== null && !out) return resolve(`grep error: ${err.trim() || code}`);
        const body = out.split('\n').map((l) => l.replace(root + path.sep, '')).join('\n');
        resolve(clip(body, RUN_CAP) + (capped ? '\n…[match output truncated]' : ''));
      });
    });

  const noFollow = async (abs) => {
    try { if ((await fsp.lstat(abs)).isSymbolicLink()) throw new Error('refusing to write through a symlink'); }
    catch (e) { if (e.code !== 'ENOENT') throw e; }
  };

  const write_file = async ({ file, content }) => {
    const abs = guard(file);
    await noFollow(abs);
    await fsp.mkdir(path.dirname(abs), { recursive: true });
    const existed = fs.existsSync(abs);
    await fsp.writeFile(abs, content, 'utf8');
    process.stderr.write(`[council] ${existed ? 'wrote' : 'created'} ${rel(abs)} (${content.length} bytes)\n`);
    return `${existed ? 'overwrote' : 'created'} ${rel(abs)}`;
  };

  const edit_file = async ({ file, old_string, new_string }) => {
    const abs = guard(file);
    await noFollow(abs);
    const text = await fsp.readFile(abs, 'utf8');
    const n = text.split(old_string).length - 1;
    if (n === 0) throw new Error('old_string not found (must match exactly)');
    if (n > 1) throw new Error(`old_string matches ${n} times; add context to make it unique`);
    await fsp.writeFile(abs, text.replace(old_string, new_string), 'utf8');
    process.stderr.write(`[council] edited ${rel(abs)}\n`);
    return `edited ${rel(abs)}`;
  };

  const run = ({ command }) =>
    new Promise((resolve) => {
      if (RUN_DENY.some((re) => re.test(command))) {
        return resolve(`[refused: command matches the destructive-command denylist]`);
      }
      process.stderr.write(`[council] $ ${command}\n`);
      // detached → its own process group, so a timeout/SIGINT can kill the whole
      // tree (descendants, backgrounded jobs), not just the bash leader.
      const ps = spawn('bash', ['-lc', command], { cwd: root, env: childEnv(), detached: true });
      activeKids.add(ps.pid);
      let out = '', err = '', timedOut = false, done = false, killTimer = null;
      const killGroup = (sig) => { try { process.kill(-ps.pid, sig); } catch { /* gone */ } };
      const timer = setTimeout(() => {
        timedOut = true; killGroup('SIGTERM');
        killTimer = setTimeout(() => killGroup('SIGKILL'), RUN_KILL_GRACE_MS); killTimer.unref();
      }, RUN_TIMEOUT_MS);
      ps.stdout.on('data', (d) => { if (out.length < RUN_CAP) out += d; });
      ps.stderr.on('data', (d) => { if (err.length < RUN_CAP) err += d; });
      const finish = (head) => {
        if (done) return; done = true;
        clearTimeout(timer); if (killTimer) clearTimeout(killTimer); // cancel any armed SIGKILL (no stray signal at a reused PGID)
        activeKids.delete(ps.pid);
        resolve(`${head}\n--- stdout ---\n${clip(out, RUN_CAP)}\n--- stderr ---\n${clip(err, RUN_CAP)}`);
      };
      ps.on('error', (e) => finish(`spawn error: ${e.message}`));
      // resolve on 'exit' (parent bash terminated) — NOT 'close', which would
      // block until inherited stdio pipes shut, hanging on backgrounded servers.
      // Sweep the group on the way out so a `cmd &` descendant can't outlive the
      // call untracked; the PGID is still ours at exit-time, so this is race-safe.
      ps.on('exit', (code, sig) => {
        if (!timedOut) killGroup('SIGTERM');
        finish(timedOut ? `[killed: exceeded ${RUN_TIMEOUT_MS / 1000}s timeout]` : `exit=${code}${sig ? ` signal=${sig}` : ''}`);
      });
    });

  // schema is the OpenRouter/OpenAI function-tool format
  const all = {
    read_file: { fn: read_file, read: true, desc: 'Read a UTF-8 file (line-numbered). Page large files with start_line/end_line.',
      params: { type: 'object', required: ['file'], properties: {
        file: { type: 'string', description: 'path relative to workspace root' },
        start_line: { type: 'integer' }, end_line: { type: 'integer' } } } },
    list_dir: { fn: list_dir, read: true, desc: 'List a directory (recursive:true for a tree, skips .git/node_modules).',
      params: { type: 'object', properties: {
        dir: { type: 'string' }, recursive: { type: 'boolean' } } } },
    glob: { fn: glob, read: true, desc: 'Find files by glob (e.g. "src/**/*.js") relative to root.',
      params: { type: 'object', required: ['pattern'], properties: { pattern: { type: 'string' } } } },
    grep: { fn: grep, read: true, desc: 'ripgrep a regex across files. Optional path and -g file glob.',
      params: { type: 'object', required: ['pattern'], properties: {
        pattern: { type: 'string' }, path: { type: 'string' }, glob: { type: 'string' } } } },
    write_file: { fn: write_file, write: true, desc: 'Create/overwrite a file (confined to root).',
      params: { type: 'object', required: ['file', 'content'], properties: {
        file: { type: 'string' }, content: { type: 'string' } } } },
    edit_file: { fn: edit_file, write: true, desc: 'Replace one unique occurrence of old_string with new_string in a file.',
      params: { type: 'object', required: ['file', 'old_string', 'new_string'], properties: {
        file: { type: 'string' }, old_string: { type: 'string' }, new_string: { type: 'string' } } } },
    run: { fn: run, write: true, desc: 'Run a shell command (bash -lc) starting in the workspace root. Use for build/tests. NOT sandboxed — does not confine you to the root; the harness API key is hidden from your environment. Backgrounded jobs (cmd &) are terminated when the command returns, so each call is self-contained — start and stop a test server within ONE command.',
      params: { type: 'object', required: ['command'], properties: { command: { type: 'string' } } } },
  };

  const enabled = Object.entries(all).filter(([, t]) => (t.read) || (caps.write && t.write));
  const schemas = enabled.map(([name, t]) => ({
    type: 'function', function: { name, description: t.desc, parameters: t.params } }));
  const registry = Object.fromEntries(enabled);
  return { schemas, registry };
};

// ---------------------------------------------------------------------------
// OpenRouter call with timeout + light retry on 429/5xx
// ---------------------------------------------------------------------------
const callOR = async (body, label) => {
  const key = process.env.OPENROUTER_API_KEY;
  for (let attempt = 0; ; attempt++) {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), HTTP_TIMEOUT_MS); // covers the body read too
    try {
      const resp = await fetch(OR_URL, {
        method: 'POST', signal: ctrl.signal,
        headers: { Authorization: `Bearer ${key}`, 'Content-Type': 'application/json', 'X-Title': 'council' },
        body: JSON.stringify(body),
      });
      if ((resp.status === 429 || resp.status >= 500) && attempt < 3) {
        const ra = Number(resp.headers.get('retry-after'));
        clearTimeout(timer);
        await sleep(ra > 0 ? Math.min(ra * 1000, 60_000) : 2000 * (attempt + 1));
        continue;
      }
      let json;
      try {
        json = await resp.json();
      } catch (e) {
        // Body read aborted (timeout) or returned non-JSON. Don't swallow to {}:
        // a 4xx is a real API error (fail fast); anything else is transient and
        // should ride the network-retry path below, not look like an empty model reply.
        clearTimeout(timer);
        if (resp.status >= 400 && resp.status < 500) throw new Error(`OpenRouter HTTP ${resp.status} (${label})`);
        throw new Error(`unreadable response body from ${label} (timeout or malformed)`);
      }
      clearTimeout(timer);
      if (json.error) {
        // OpenRouter surfaces some provider failures as HTTP 200 + {error}. Retry
        // the transient ones (429/5xx/overload/"provider returned error"); a real
        // bad-request (4xx) fails fast.
        const code = Number(json.error.code) || resp.status;
        const transient = code === 429 || code >= 500 ||
          /overload|temporar|timeout|provider returned error|rate.?limit/i.test(json.error.message || '');
        if (transient && attempt < 3) { await sleep(2000 * (attempt + 1)); continue; }
        throw new Error(`OpenRouter error (${label}): ${json.error.message || JSON.stringify(json.error)}`);
      }
      if (!resp.ok) throw new Error(`OpenRouter HTTP ${resp.status} (${label})`);
      return json;
    } catch (e) {
      clearTimeout(timer);
      if (e.message?.startsWith('OpenRouter')) throw e; // surfaced API error: already decided not to retry
      if (attempt < 2) { await sleep(1500 * (attempt + 1)); continue; }
      throw new Error(`network error talking to OpenRouter (${label}): ${e.message}`);
    }
  }
};

// ---------------------------------------------------------------------------
// One agentic tool loop for a single model.
// ---------------------------------------------------------------------------
const runAgent = async ({ model, effort, system, user, tools, maxSteps, label, provider }) => {
  const messages = [{ role: 'system', content: system }, { role: 'user', content: user }];
  let cost = 0;
  try { return await agentLoop(); }
  catch (e) { e.cost = (e.cost || 0) + cost; throw e; } // preserve partial spend for council totals

  async function agentLoop() {
  for (let step = 0; step < maxSteps; step++) {
    const body = {
      model, messages, provider,
      tools: tools.schemas, usage: { include: true },
    };
    if (effort && effort !== 'none') body.reasoning = { effort };
    const json = await callOR(body, label || model);
    cost += json.usage?.cost || 0;
    const msg = json.choices?.[0]?.message;
    if (!msg) throw new Error(`empty response from ${model}`);
    messages.push(msg); // preserve assistant turn verbatim (tool_calls/reasoning)

    const calls = msg.tool_calls || [];
    if (!calls.length) {
      return { text: msg.content || '(no content)', cost, steps: step + 1, capped: false };
    }
    for (const call of calls) {
      const name = call.function?.name;
      const t = tools.registry[name];
      let result;
      try {
        const args = JSON.parse(call.function?.arguments || '{}');
        if (!t) throw new Error(`unknown tool ${name}`);
        process.stderr.write(`[council:${label}] → ${name} ${JSON.stringify(args).slice(0, 120)}\n`);
        result = await t.fn(args);
      } catch (e) {
        result = `error: ${e.message}`;
      }
      messages.push({ role: 'tool', tool_call_id: call.id, content: String(result) });
    }
  }
  // out of steps — ask once for a final answer. Tools stay in the request
  // (some providers reject tool history when `tools` is absent) but tool_choice
  // forces a text answer.
  const json = await callOR({ model, messages: [...messages,
    { role: 'user', content: 'Step budget reached. Give your best final answer now using what you have gathered.' }],
    provider, tools: tools.schemas, tool_choice: 'none', usage: { include: true } }, label || model);
  cost += json.usage?.cost || 0;
  return { text: json.choices?.[0]?.message?.content || '(no content)', cost, steps: maxSteps, capped: true };
  }
};

// ---------------------------------------------------------------------------
// Council: each member runs its own tool loop (read-only), chair reconciles.
// ---------------------------------------------------------------------------
const runCouncil = async ({ panel, chair, effort, system, user, root, maxSteps, provider }) => {
  process.stderr.write(`[council] panel: ${panel.join(', ')}  ·  chair: ${chair}\n`);
  const members = await Promise.all(panel.map(async (model) => {
    const tools = makeTools(root, makeGuard(root), { write: false }); // council is advisory → read-only
    try {
      const r = await runAgent({ model, effort, system, user, tools, maxSteps, label: model.split('/').pop(), provider });
      return { model, ...r };
    } catch (e) {
      process.stderr.write(`[council] member ${model} failed: ${e.message}\n`);
      return { model, text: `(member failed: ${e.message})`, cost: e.cost || 0, failed: true };
    }
  }));
  const ok = members.filter((m) => !m.failed);
  if (!ok.length) die('all council members failed');

  const memberBlock = members.map((m, i) =>
    `===== MEMBER ${i + 1}: ${m.model}${m.failed ? ' (FAILED)' : ''} =====\n${m.text}`).join('\n\n');
  const chairSystem =
    'You are the CHAIR of an engineering council. Independent members each answered the SAME task after reading the codebase. Reconcile their views BY EVIDENCE, not majority vote: a single member with a concrete repro / cited file:line / failed invariant outweighs the others. Produce ONE answer: the agreed conclusion, the load-bearing disagreements and how you resolved each, and anything still uncertain. Be concise. Note which member contributed each load-bearing point.';
  const chairUser = `ORIGINAL TASK:\n${user}\n\nMEMBER RESPONSES:\n\n${memberBlock}`;
  const json = await callOR({ model: chair, messages: [
    { role: 'system', content: chairSystem }, { role: 'user', content: chairUser }],
    provider, usage: { include: true },
    ...(effort && effort !== 'none' ? { reasoning: { effort } } : {}) }, `chair:${chair}`);
  const cost = members.reduce((s, m) => s + (m.cost || 0), 0) + (json.usage?.cost || 0);
  return { text: json.choices?.[0]?.message?.content || '(no content)', cost, members };
};

// ---------------------------------------------------------------------------
// stdin (seed material), like xcheck
// ---------------------------------------------------------------------------
// Drain piped stdin, but NEVER block: a non-TTY idle pipe (headless Bash/CI/editor
// integration) has no EOF, so give up if nothing arrives, and cap total bytes.
const readStdin = () => new Promise((resolve) => {
  if (process.stdin.isTTY) return resolve('');
  const chunks = []; let len = 0, done = false;
  const finish = () => {
    if (done) return; done = true;
    clearTimeout(idle); process.stdin.removeAllListeners(); process.stdin.pause();
    resolve(Buffer.concat(chunks).toString('utf8'));
  };
  const idle = setTimeout(finish, 3000); // no first byte ⇒ assume no piped input
  process.stdin.on('data', (c) => { if (len < 1024 * 1024) { chunks.push(c); len += c.length; } idle.refresh(); });
  process.stdin.on('end', finish);
  process.stdin.on('error', finish);
});

const HELP = `council — agentic OpenRouter harness with local-file access + council mode

USAGE
  council [options] <prompt...>

MODES (--mode, default: plan)   set the system prompt + default capabilities
  ask       read-only  · answer a question about the code (cite file:line)
  plan      read-only  · produce an implementation plan
  review    read-only  · adversarial bug/design review
  build     write+run  · implement the change under --root, verify with tests
  test      write+run  · run the project's tests/build and report

CAPABILITY (--sandbox)          override the mode default
  read-only   read_file/list_dir/glob/grep only            (council always uses this)
  write       also write_file/edit_file (confined to --root) + run (full shell,
              starts in --root but NOT sandboxed — see SAFETY)

COUNCIL
  --council                fan out to a panel, then a chair reconciles (read-only)
  --panel m1,m2,m3         panel model ids   (default: ${DEFAULT_PANEL.join(', ')})
  --chair MODEL            synthesizer       (default: ${DEFAULT_CHAIR})

PROVIDER ROUTING (OpenRouter — applies to every model call: members + chair)
  --provider p1,p2         primary upstream provider(s), tried in this order
  --backup-provider p3,p4  backup provider(s), tried after the primaries
  --allow-fallbacks        if all named providers fail, allow any other (default: off)
                           (off = strict: only the named providers, in order)
  slugs are OpenRouter provider ids, e.g. openai, anthropic, together, deepinfra,
  fireworks, novita — see a model's providers at openrouter.ai/<model>

MODEL / SCOPE
  -m, --model MODEL        single-model id   (default: ${DEFAULT_MODEL})
  -e, --effort LEVEL       low|medium|high|none   (default: high)
  --root DIR               workspace the tools are confined to (default: cwd)
  --max-steps N            tool-call iterations per agent (default: ${MAX_STEPS})
  -f, --files a,b          seed files injected into the prompt (model can read more)
  -q, --quiet              print only the final answer (no header/usage)
  -h, --help

ENV   OPENROUTER_API_KEY (required) · COUNCIL_MODEL · COUNCIL_PANEL · COUNCIL_CHAIR
      · COUNCIL_PROVIDER · COUNCIL_BACKUP_PROVIDER · COUNCIL_ALLOW_FALLBACKS

SAFETY  read_file/list_dir/glob/grep/write_file/edit_file are confined to --root
        (symlink-escape + no-follow-write guarded). \`run\` and writes need
        --sandbox write. \`run\` is full bash on YOUR machine — it STARTS in --root
        but is NOT confined (cd .., absolute paths escape) and is NOT a sandbox;
        the denylist is only a speed-bump. OPENROUTER_API_KEY is stripped from its
        env. For untrusted tasks run council inside a container/VM. --council
        forces read-only, so panel members never write or run.

EXAMPLES
  council "plan adding rate limiting to the /chat route"
  council --mode review -f src/db.js "find SQLi and race conditions"
  council --council "is the auth refactor in this repo safe to ship?"
  council --mode build --root . "make the failing test in test/auth.test.js pass"
  council -m deepseek/deepseek-chat --provider deepinfra --backup-provider novita,fireworks "explain db.js"
  council --provider openai --allow-fallbacks "summarize this module"`;

// ---------------------------------------------------------------------------
const main = async () => {
  let parsed;
  try {
    parsed = parseArgs({ allowPositionals: true, options: {
      model: { type: 'string', short: 'm' },
      effort: { type: 'string', short: 'e', default: 'high' },
      mode: { type: 'string', default: 'plan' },
      sandbox: { type: 'string' },
      council: { type: 'boolean', default: false },
      panel: { type: 'string' },
      chair: { type: 'string', default: DEFAULT_CHAIR },
      provider: { type: 'string' },
      'backup-provider': { type: 'string' },
      'allow-fallbacks': { type: 'boolean', default: false },
      root: { type: 'string', default: process.cwd() },
      'max-steps': { type: 'string' },
      files: { type: 'string', short: 'f' },
      quiet: { type: 'boolean', short: 'q', default: false },
      help: { type: 'boolean', short: 'h', default: false },
    } });
  } catch (e) { die(e.message, 2); }
  const o = parsed.values;
  if (o.help) { process.stdout.write(HELP + '\n'); return; }
  if (!process.env.OPENROUTER_API_KEY) die('set OPENROUTER_API_KEY (https://openrouter.ai/keys)', 2);

  const mode = MODES[o.mode];
  if (!mode) die(`unknown --mode ${o.mode} (ask|plan|review|build|test)`, 2);

  let root;
  try { root = fs.realpathSync(path.resolve(o.root)); }
  catch { die(`--root does not exist: ${o.root}`, 2); }

  const isCouncil = o.council || !!o.panel;
  const sandbox = isCouncil ? 'read-only' : (o.sandbox || mode.sandbox);
  if (!['read-only', 'write'].includes(sandbox)) die(`--sandbox must be read-only|write`, 2);

  // OpenRouter provider routing (applies to every model call: members + chair).
  const provider = buildProvider(
    o.provider ?? process.env.COUNCIL_PROVIDER,
    o['backup-provider'] ?? process.env.COUNCIL_BACKUP_PROVIDER,
    o['allow-fallbacks'] || process.env.COUNCIL_ALLOW_FALLBACKS === 'true',
  );
  const caps = { write: sandbox === 'write' };
  const maxSteps = o['max-steps'] ? parseInt(o['max-steps'], 10) : MAX_STEPS;

  // assemble the user message: prompt + seed material (stdin, -f files)
  const promptText = parsed.positionals.join(' ').trim();
  const stdin = await readStdin();
  const seeds = [];
  // -f is operator-supplied (their machine, their choice) so it may point
  // outside --root, but cap the size so a giant file can't blow the context.
  for (const f of csv(o.files)) {
    try {
      const p = path.resolve(root, f);
      const sz = fs.statSync(p).size;
      const body = fs.readFileSync(p, 'utf8');
      seeds.push(`===== SEED FILE: ${f}${sz > SEED_CAP ? ` (truncated to ${SEED_CAP}B)` : ''} =====\n${clip(body, SEED_CAP)}`);
    } catch (e) { die(`-f ${f}: ${e.message}`, 2); }
  }
  if (stdin.trim()) seeds.push(`===== STDIN =====\n${stdin.trim()}`);
  if (!promptText && !seeds.length) die('nothing to do — give a prompt (or -f file / stdin). See -h.', 2);

  const user = [
    promptText || 'Review the seed material below.',
    `\nWorkspace root: ${root}  (use the tools to explore; paths are relative to root)`,
    seeds.length ? `\n${seeds.join('\n\n')}` : '',
  ].join('\n');

  const t0 = Date.now();
  let out;
  const provTag = provider.order
    ? ` · providers=${provider.order.join('>')}${provider.allow_fallbacks ? '>*' : ''}`
    : '';
  if (isCouncil) {
    const panel = o.panel ? csv(o.panel) : DEFAULT_PANEL;
    out = await runCouncil({ panel, chair: o.chair, effort: o.effort, system: mode.system, user, root, maxSteps, provider });
  } else {
    const model = o.model || DEFAULT_MODEL;
    const tools = makeTools(root, makeGuard(root), caps);
    if (!o.quiet) process.stderr.write(`[council] ${model} · mode=${o.mode} · sandbox=${sandbox}${provTag}\n`);
    out = await runAgent({ model, effort: o.effort, system: mode.system, user, tools, maxSteps, label: model.split('/').pop(), provider });
  }

  if (!o.quiet) {
    const secs = ((Date.now() - t0) / 1000).toFixed(1);
    const tag = isCouncil ? `council[${(o.panel ? csv(o.panel) : DEFAULT_PANEL).length}]→${o.chair}` : (o.model || DEFAULT_MODEL);
    process.stderr.write(`── council · ${tag} · mode=${o.mode} · sandbox=${sandbox}${provTag} · ${secs}s · $${(out.cost || 0).toFixed(4)} ──\n`);
  }
  process.stdout.write(out.text + '\n');
};

if (require.main === module) main().catch((e) => die(e.message));
else module.exports = { makeGuard, makeTools, callOR, runAgent, runCouncil, buildProvider }; // for tests
